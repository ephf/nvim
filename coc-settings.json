{
	"inlayHint.enable": false,
	"clangd.arguments": [
		"--function-arg-placeholders=0"
	],
	"html.validate.styles": false,
	"languageserver": {
		"tinymist": {
			"command": "tinymist",
			"filetypes": ["typst"],
			"settings": {
				"formatterMode": "typstyle",
				"exportPdf": "onSave"
			}
		}
  }
}
